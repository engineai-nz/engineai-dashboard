# Phase 1a env contract.
# Copy to .env.local and fill in. Lazy-throws on first use if missing.

# Supabase — server-side
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase — browser-side (must match server URL/anon key)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# LLM provider — agents resolve their model via src/lib/agents/model.ts.
# Phase 1a is a holding pattern; this is the only file you touch to swap.
# Supported: anthropic, minimax. Add more providers in model.ts.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5
ANTHROPIC_API_KEY=

# Minimax (local testing only — NOT for production).
# To use: set LLM_PROVIDER=minimax, LLM_MODEL=MiniMax-M2.7, fill key below.
# MINIMAX_BASE_URL defaults to https://api.minimax.io/v1.
MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.io/v1

# Phase 1b — Linear MCP integration.
# Read ONCE in src/lib/mcp/linear-client.ts (the only file in the codebase
# allowed to touch this secret — sealed envelope rule, grep-enforced in
# the Phase 1b exit criteria). Everything above that layer calls
# getLinearMcpClient() and only ever sees the MCP Client object.
# Get a key from https://linear.app/settings/account/security.
# Leave empty in local dev if you are not exercising the Linear post path;
# linear-client.ts throws at first use, not at import time.
LINEAR_API_KEY=

# Phase 1.5 escape hatch — DO NOT set in production unless you know why.
# ALLOW_DEV_TENANT_IN_PROD=true
